# =============================================================================
# TEMPLATE IN GIT — This file is committed. It has NO real secrets.
#
# YOU KEEP AND EDIT LOCALLY: after clone, run:
#   cp .env.example .env
# Then fill `.env` with YOUR Snowflake (and optional Airflow) settings.
# `.env` is gitignored — never commit it.
#
# See README: "Local-only files you must keep and configure".
# =============================================================================
#
# Required for a typical setup (use values from YOUR Snowflake account):
#   SNOWFLAKE_ACCOUNT, SNOWFLAKE_USER, SNOWFLAKE_DATABASE,
#   SNOWFLAKE_WAREHOUSE, SNOWFLAKE_ROLE
# Plus: path to YOUR unencrypted RSA private key (.p8) → SNOWFLAKE_PRIVATE_KEY
#
# Optional: SNOWFLAKE_SCHEMA, SNOWFLAKE_WAREHOUSE_FALLBACKS (see README).
# =============================================================================

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
# Default schema for app objects; change only if your project uses another schema.
SNOWFLAKE_SCHEMA=MARKETLENS
SNOWFLAKE_WAREHOUSE=
# If USE WAREHOUSE fails (object does not exist), try these next (comma-separated).
SNOWFLAKE_WAREHOUSE_FALLBACKS=SCORPION_WH
SNOWFLAKE_ROLE=
# Path to your PKCS#8 PEM private key (unencrypted). Not committed to git.
SNOWFLAKE_PRIVATE_KEY=${HOME}/airflow/snowflake_rsa_key.p8

# Local Airflow (used by `scripts/airflow_standalone.sh`)
# AIRFLOW_HOME defaults to `<repo>/.airflow` if unset when running the script
# AIRFLOW_HOME=
AIRFLOW__CORE__LOAD_EXAMPLES=False
